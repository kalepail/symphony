LINEAR_API_KEY=replace-me
SYMPHONY_WORKSPACE_ROOT=/tmp/symphony-rust
SYMPHONY_SMOKE_PROJECT_SLUG=replace-me

# Rust's checked-in smoke workflows currently target a dedicated pre-seeded Linear project.
# This differs from Elixir's repo-owned live_e2e harness, which creates a disposable project
# from a team key and therefore only needs LINEAR_API_KEY by default.
