TODOIST_API_TOKEN=replace-me
SYMPHONY_WORKSPACE_ROOT=/tmp/symphony-todoist
SYMPHONY_SMOKE_PROJECT_ID=replace-me
SYMPHONY_RUN_LIVE_E2E=1
# Optional but recommended for stable GitHub publish/merge flows:
# use a classic token with repo access, or populate this from `gh auth token`.
# GH_TOKEN=gho_xxx

# Rust Todoist smoke runs intentionally reuse a dedicated Todoist project so the canonical
# sections and smoke labels stay stable across minimal/full/rework/merge scenarios.
